# Détection auto pour la plupart des fichiers
* text=auto

# Scripts shell Unix : forcer LF (sinon le shebang #! casse sous macOS/Linux)
*.sh   text eol=lf
*.command text eol=lf

# Scripts batch Windows : forcer CRLF (cmd.exe attend des CRLF)
*.bat  text eol=crlf

# Binaires (pour éviter toute conversion)
*.png  binary
*.ico  binary
*.pdf  binary
